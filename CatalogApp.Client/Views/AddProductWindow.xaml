<Window x:Class="CatalogApp.Client.Views.AddProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CatalogApp.Client.Views"
        mc:Ignorable="d"
        Title="Добавить товар" Height="450" Width="800" WindowStartupLocation="CenterOwner">

    <Grid>
        <Border Style="{StaticResource Card}" Margin="12">
            <StackPanel>
                <StackPanel>
                    <TextBox 
                        Style="{StaticResource PlaceholderTextBox}"
                        Tag="Название продукта"
                        Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,6"/>
                    <TextBlock Text="{Binding NameError}" Foreground="Tomato" FontSize="12" Margin="4,0,0,6" Visibility="{Binding NameError, Converter={StaticResource StringToVisibilityConverter}}"/>
                </StackPanel>
                <TextBox 
                    Style="{StaticResource PlaceholderTextBox}"
                    Tag="Описание"
                    Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Margin="0,6" Height="80" AcceptsReturn="True"/>
                <StackPanel>
                    <TextBox 
                        Style="{StaticResource PlaceholderTextBox}"
                        Tag="Цена" 
                        Text="{Binding Price, UpdateSourceTrigger=PropertyChanged}" Margin="0,6"/>
                    <TextBlock Text="{Binding PriceError}" Foreground="Tomato" FontSize="12" Margin="4,0,0,6" Visibility="{Binding PriceError, Converter={StaticResource StringToVisibilityConverter}}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,6">
                    <Button Content="Выберите картинку" Command="{Binding ChooseFileCommand}"/>
                    <TextBlock Text="{Binding SelectedFile}" Margin="8,0,0,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Width="220"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button 
                        Content="Создать" 
                        Command="{Binding UploadCreateCommand}" 
                        Width="140"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
