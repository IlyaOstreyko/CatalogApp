<Window x:Class="CatalogApp.Client.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CatalogApp.Client.Views"
        xmlns:helpers="clr-namespace:CatalogApp.Client.Resources"
        mc:Ignorable="d"
        Title="Вход" Height="450" Width="800" WindowStartupLocation="CenterScreen">
    <Grid>    


        <Border Style="{StaticResource Card}" HorizontalAlignment="Center" VerticalAlignment="Center" Width="360">
            <StackPanel>
                <TextBlock Text="Вход" FontSize="26" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>
                <TextBox 
                    Style="{StaticResource PlaceholderTextBox}"
                    Tag="Имя Пользователя"
                    Margin="0,12,0,6" 
                    Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>
                <PasswordBox 
    Style="{StaticResource PlaceholderPasswordBox}"
    Tag="Введите пароль"
    Margin="0,6,0,6"
    helpers:PasswordBoxHelper.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <!-- Error message -->
                <TextBox Style="{StaticResource ErrorTextBox}"
         Text="{Binding ErrorMessage}"/>
                <StackPanel Orientation="Horizontal"
            HorizontalAlignment="Right"
            Margin="0,8,0,0">

                    <Button Content="Вход"
            Width="100"
            Margin="0,0,8,0"
            Command="{Binding LoginCommand}" IsEnabled="{Binding CanLogin}"/>

                    <Button Content="Регистрация"
            Width="100"
            Command="{Binding RegisterCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
