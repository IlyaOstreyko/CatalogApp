<Window x:Class="CatalogApp.Client.Views.RegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CatalogApp.Client.Views"
        xmlns:helpers="clr-namespace:CatalogApp.Client.Resources"
        Title="CatalogApp — Registration"
        Height="500" Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Border Style="{StaticResource Card}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="360">

            <StackPanel>

                <TextBlock Text="Регистрация"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center"/>

                <!-- Username -->
                <TextBox 
                    Style="{StaticResource PlaceholderTextBox}"
                    Tag="Имя пользователя"
                    Margin="0,12,0,6"
                    Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Email -->
                <TextBox 
                    Style="{StaticResource PlaceholderTextBox}"
                    Tag="Email"
                    Margin="0,6,0,6"
                    Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Password -->
                <PasswordBox 
                    Style="{StaticResource PlaceholderPasswordBox}"
                    Tag="Введите пароль"
                    Margin="0,6,0,6"
                    
                    helpers:PasswordBoxHelper.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Confirm Password -->
                <PasswordBox 
                    Style="{StaticResource PlaceholderPasswordBox}"
                    Tag="Повторите пароль"
                    Margin="0,6,0,6"
                    helpers:PasswordBoxHelper.BoundPassword="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <!-- Error message -->
                <TextBox Style="{StaticResource ErrorTextBox}"
Text="{Binding ErrorMessage}"/>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,8,0,0">
                    <Button Content="Назад"
        Width="100"
        Margin="0,0,8,0"
                            
        Command="{Binding BackCommand}" />

                    <Button Content="Создать"
        Width="100"
        Command="{Binding RegisterCommand}" IsEnabled="{Binding CanRegister}"/>
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Window>
