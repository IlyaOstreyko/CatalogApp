<Window x:Class="CatalogApp.Client.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CatalogApp.Client.ViewModels"
        xmlns:local="clr-namespace:CatalogApp.Client.Views"
        mc:Ignorable="d"
        
        Title="CatalogApp" Height="450" Width="800" WindowStartupLocation="CenterScreen">


    <Grid Margin="12">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Style="{StaticResource Card}">
            <DockPanel Grid.Row="0" Margin="0,0,0,8">
            
            <TextBlock Text="Catalog" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Content="Add Product" Margin="10,0,8,0" Command="{Binding AddProductCommand}"/>
                <Button Content="Refresh" Command="{Binding RefreshCommand}"/>
                    <!-- Error message -->
                    <TextBox Style="{StaticResource ErrorTextBox}"
         Text="{Binding ErrorMessage}"/>
                </StackPanel>
            
        </DockPanel>
        </Border>
        <ListView Grid.Row="1" ItemsSource="{Binding Products}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource Card}">
                        <DockPanel>
                            <Image Width="100" 
                                   Height="100" 
                                   Source="{Binding ImageSource}" 
                                   Stretch="UniformToFill" 
                                   Margin="0,0,12,0" MouseLeftButtonUp="Image_MouseLeftButtonUp"
       Cursor="Hand" />
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14"/>
                                <TextBlock Text="{Binding Description}" TextWrapping="Wrap" MaxWidth="700"/>
                                <TextBlock Text="{Binding Price, StringFormat=C}" Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        
    </Grid>
</Window>
